# Environment (development, staging, production)
ENVIRONMENT=development

# Database Connection (use localhost if running outside Docker)
DATABASE_URL=postgresql://postgres:password123@localhost:5432/gameai
REDIS_URL=redis://localhost:6379/0

# Security (Minimum 32 characters)
JWT_SECRET_KEY=y0ur_v3ry_s3cr3t_k3y_h3r3_m4k3_1t_l0ng_3n0ugh
JWT_ALGORITHM=HS256

# CORS
ALLOW_ORIGINS=http://localhost:3000

# Feature Flags
BYPASS_EMAIL_VERIFICATION=True

# Match limits
MAX_TURN_TIME_LIMIT_SECONDS=120

# Rate limiting. Limit strings use the slowapi/limits format; combine
# multiple windows with ";" (e.g. "10/minute;60/hour"). Authenticated
# requests are keyed by user id, anonymous by client IP, valid worker
# API keys are exempt.
RATE_LIMITING_ENABLED=true
# Dev/test only; MUST be false in production (config load fails otherwise).
RATE_LIMIT_BYPASS=false
# Shared-IP (hackathon) mode: drop IP-keyed limits, keep user-id limits.
DISABLE_IP_RATE_LIMITING=false
# Trust X-Forwarded-For for the client IP. Only enable behind a reverse
# proxy that sets/appends the header. Default false.
TRUST_PROXY_HEADERS=false
# Per-category limits (defaults shown).
RATE_LIMIT_LOGIN=10/minute;60/hour
RATE_LIMIT_REGISTER=6/minute;40/hour
RATE_LIMIT_EMAIL_TOKEN=6/minute;20/hour
RATE_LIMIT_READS=600/minute;10000/hour
RATE_LIMIT_PROFILE=120/minute
RATE_LIMIT_MUTATIONS=120/minute;2000/hour
RATE_LIMIT_UPLOAD=10/minute;60/hour
RATE_LIMIT_MATCH_CREATE=20/minute;200/hour
RATE_LIMIT_STREAM=60/minute
RATE_LIMIT_ADMIN=20000/minute
