# M-9: the base image should be pinned to an immutable digest in production, e.g.
#   --build-arg BASE_IMAGE=ghcr.io/ai-club-aachen/game-ai-platform/agent-base@sha256:<digest>
# The ':latest' default is mutable and must not be relied on for a real deployment.
ARG BASE_IMAGE=ghcr.io/ai-club-aachen/game-ai-platform/agent-base:latest
FROM ${BASE_IMAGE}

WORKDIR /home/runner/app
COPY . .

ARG AGENT_FILE=agent.py
ENV AGENT_FILE=${AGENT_FILE}
ENV PYTHONUNBUFFERED=1
ENV AGENT_ONLINE=1

CMD ["python", "-u", "-c", "import os, runpy; runpy.run_path(os.environ.get('AGENT_FILE', 'agent.py'), run_name='__main__')"]