# ==========================================================
# Game AI Platform - Complete Environment Template
# Copy this file to .env for local Docker Compose, or enter the same
# variables in Dokploy. docker-compose.yml intentionally uses required
# variable validation for most values so missing env config fails fast.
# ==========================================================

# ----------------------------------------------------------
# Environment
# Options: development, staging, production
# ----------------------------------------------------------
ENVIRONMENT=production


# ----------------------------------------------------------
# PostgreSQL container configuration
# Used by docker-compose service: db
# POSTGRES_PORT is only used by docker-compose.override.yml for local
# development host access. Dokploy production does not publish this port.
# ----------------------------------------------------------
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change-me-to-a-strong-postgres-password
POSTGRES_DB=gameai
POSTGRES_PORT=5432


# ----------------------------------------------------------
# Backend database connection
# The root docker-compose.yml builds DATABASE_URL automatically from
# POSTGRES_USER, POSTGRES_PASSWORD, and POSTGRES_DB, so you usually do
# not need to set it for Dokploy / Docker Compose deployments.
#
# Only set this if you run the backend outside the root compose setup
# or want to override the generated database connection.
# Inside Docker Compose, the default host is the stable network alias
# "gameai-postgres". This avoids conflicts with external Dokploy/Docker
# DNS entries named "db" and avoids generated container names.
# ----------------------------------------------------------
# DATABASE_URL=postgresql://${POSTGRES_USER}:${POSTGRES_PASSWORD}@gameai-postgres:5432/${POSTGRES_DB}


# Optional DB logging.
# Recommended production value: false
DB_ECHO=false

# Seeds development/demo data when set to true.
# Recommended production value: false
SEED_DB=false


# ----------------------------------------------------------
# Redis
# Used by backend and orchestration workers.
# Inside Docker Compose, host must be "redis".
# ----------------------------------------------------------
REDIS_URL=redis://redis:6379/0


# ----------------------------------------------------------
# Backend server / API configuration
# BACKEND_PORT is only used by docker-compose.override.yml for local
# development host access. Dokploy production should route internally.
# ----------------------------------------------------------
BACKEND_PORT=8000
API_V1_PREFIX=/api/v1
PROJECT_NAME="GameAI Competition Platform"
LOG_LEVEL=info

# ----------------------------------------------------------
# Rate limiting
# Limit strings use the slowapi/limits format; combine multiple
# windows with ";" (e.g. "10/minute;60/hour").
# Authenticated requests are keyed by user id, anonymous requests by
# client IP, and requests with a valid WORKER_API_KEY are exempt.
# ----------------------------------------------------------

# Master rate-limiting switch. Disable only for dev/test (used in CI compose);
# MUST be true in production — config load fails if false while ENVIRONMENT=production.
RATE_LIMITING_ENABLED=true

# Shared-IP (hackathon) mode: drops IP-keyed limits for anonymous
# requests while keeping per-user-id limits. Recommended: false.
DISABLE_IP_RATE_LIMITING=false

# Trust X-Forwarded-For for the client IP. Enable ONLY when the backend
# runs behind a reverse proxy that sets/appends the header (the
# proxy-adjacent, right-most hop is used). Default: false.
TRUST_PROXY_HEADERS=false

# Per-category limits (defaults shown).
RATE_LIMIT_LOGIN=10/minute;60/hour
RATE_LIMIT_REGISTER=6/minute;40/hour
# Email verification + password reset endpoints.
RATE_LIMIT_EMAIL_TOKEN=6/minute;20/hour
# Global default for all routes without an explicit category.
RATE_LIMIT_READS=600/minute;10000/hour
RATE_LIMIT_PROFILE=120/minute
RATE_LIMIT_MUTATIONS=120/minute;2000/hour
RATE_LIMIT_UPLOAD=10/minute;60/hour
RATE_LIMIT_MATCH_CREATE=20/minute;200/hour
# SSE match-stream connection attempts.
RATE_LIMIT_STREAM=60/minute
RATE_LIMIT_ADMIN=20000/minute


# ----------------------------------------------------------
# Security / JWT
# Generate with: openssl rand -hex 32
# JWT_SECRET_KEY must be at least 32 characters.
# ----------------------------------------------------------
JWT_SECRET_KEY=change-me-generate-with-openssl-rand-hex-32
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_HOURS=24


# ----------------------------------------------------------
# CORS / public frontend URL
# In production, ALLOW_ORIGINS must use https:// URLs.
# IMPORTANT: use comma-separated values only. Do not use JSON brackets/quotes.
# Production frontend: https://game-ai.ai-club-aachen.com
# Local frontend: http://localhost:3000
# Multiple domains example:
# ALLOW_ORIGINS=https://game-ai.ai-club-aachen.com,https://www.whatever.ai-club-aachen.com
# ----------------------------------------------------------
ALLOW_ORIGINS=https://game-ai.ai-club-aachen.com
FRONTEND_URL=https://game-ai.ai-club-aachen.com

# Hostnames accepted by the backend TrustedHostMiddleware.
# Must include the public API hostname used by browsers/reverse proxies.
# Do not include paths. Protocols are tolerated but not needed.
TRUSTED_HOSTS=api.game-ai.ai-club-aachen.com


# ----------------------------------------------------------
# Frontend / Vite
# FRONTEND_PORT is only used by docker-compose.override.yml for local
# development host access. Dokploy production should route internally.
# ----------------------------------------------------------
FRONTEND_PORT=3000

# ----------------------------------------------------------
# Frontend runtime config
# Used by frontend/src/services/api/client.ts
# For Dokploy production, this should be the public backend URL.
# Production backend API: https://api.game-ai.ai-club-aachen.com/api/v1
# Local backend API: http://localhost:8000/api/v1
# ----------------------------------------------------------
VITE_API_URL=https://api.game-ai.ai-club-aachen.com/api/v1

# Used by frontend vite.config.ts and frontend MatchManagement page.
MAX_TURN_TIME_LIMIT_SECONDS=120


# ----------------------------------------------------------
# Email / SMTP
# Required when ENVIRONMENT=staging or ENVIRONMENT=production.
# Optional in development.
# ----------------------------------------------------------
SMTP_HOST=your-smtp-host.example.com
SMTP_PORT=465
SMTP_USERNAME=your-smtp-username
SMTP_PASSWORD=your-smtp-password
SMTP_FROM_ADDRESS=noreply@your-domain.com
SMTP_FROM_NAME=AI Game Platform
SMTP_USE_TLS=true

# Email verification and password reset token expiry.
# EMAIL_VERIFICATION_TOKEN_EXPIRE_HOURS valid range: 1-168
# PASSWORD_RESET_TOKEN_EXPIRE_MINUTES valid range: 5-1440
EMAIL_VERIFICATION_TOKEN_EXPIRE_HOURS=24
PASSWORD_RESET_TOKEN_EXPIRE_MINUTES=60

# Development bypass. MUST be false in production.
BYPASS_EMAIL_VERIFICATION=False


# ----------------------------------------------------------
# Worker authentication
# Used by backend to authenticate orchestration workers,
# and by orchestration workers when calling backend.
# Generate with: openssl rand -hex 32
# ----------------------------------------------------------
WORKER_API_KEY=change-me-generate-with-openssl-rand-hex-32


# ----------------------------------------------------------
# Orchestration workers
# docker-compose maps WORKER_BACKEND_URL into worker env var BACKEND_URL.
# Inside Docker Compose, keep this internal URL.
# Do NOT use the public api domain here unless workers run outside compose.
# ----------------------------------------------------------
WORKER_BACKEND_URL=http://backend:8000/api/v1
WORKER_LOG_LEVEL=INFO

# If true, agent-builder tries to build the local base image.
# Recommended production value: False, assuming the base image is available remotely.
BUILD_LOCAL_BASE_IMAGE=False

# Registry credentials required when building the local base image
DOCKER_REGISTRY_USER=
DOCKER_REGISTRY_PASSWORD=

# Build and run workers with local gamelib instead of installing from PyPI.
USE_LOCAL_GAMELIB=False

# This variable is read directly by orchestration/lib/backend_api.py
# if workers are started outside docker-compose.
# In docker-compose, BACKEND_URL is generated from WORKER_BACKEND_URL.
BACKEND_URL=http://backend:8000/api/v1


# ----------------------------------------------------------
# Backend match/job behavior
# These are optional backend settings with defaults.
# ----------------------------------------------------------
MATCH_STALE_TIMEOUT_SECONDS=60
MAX_AGENTS_PER_GAME=3

# Upload limits (H-4). MAX_UPLOAD_BYTES=0 disables the size cap;
# MAX_SUBMISSIONS_PER_USER=0 disables the per-user quota.
MAX_UPLOAD_BYTES=10485760
MAX_SUBMISSIONS_PER_USER=0


# ----------------------------------------------------------
# Backend filesystem paths
# Usually do not change these unless you also adjust volumes.
# ----------------------------------------------------------
UPLOAD_DIR=uploads
SUBMISSIONS_DIR=uploads/submissions


# ----------------------------------------------------------
# Test-only / development-only
# Used by backend/tests/conftest.py.
# Not needed for Dokploy production.
# ----------------------------------------------------------
TEST_DATABASE_URL=postgresql://postgres:change-me-to-a-strong-postgres-password@db:5432/gameai_test


# ----------------------------------------------------------
# Agent/gamelib example variable
# Used by example agents to decide whether to run in online mode.
# Usually not needed in platform deployment .env.
# ----------------------------------------------------------
AGENT_ONLINE=0