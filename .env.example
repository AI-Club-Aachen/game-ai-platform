# ==========================================================
# Game AI Platform - environment template
# Copy to .env for local Docker Compose, or set the same vars in Dokploy.
# Defaults below are the AI Club production setup; "local:" notes show the
# local-dev value where it differs.
# ==========================================================

# ----------------------------------------------------------
# Environment: development | staging | production
# local: development   prod: production
# ----------------------------------------------------------
ENVIRONMENT=production


# ----------------------------------------------------------
# PostgreSQL (compose service: db)
# POSTGRES_PORT exposes the DB on the host for local dev only.
# ----------------------------------------------------------
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change-me-to-a-strong-postgres-password
POSTGRES_DB=gameai
POSTGRES_PORT=5432


# ----------------------------------------------------------
# Database connection
# Compose builds DATABASE_URL from the POSTGRES_* values above.
# Set it only to run the backend outside compose.
# ----------------------------------------------------------
# DATABASE_URL=postgresql://${POSTGRES_USER}:${POSTGRES_PASSWORD}@gameai-postgres:5432/${POSTGRES_DB}
DB_ECHO=false
SEED_DB=false
DATABASE_POOL_SIZE=20
DATABASE_MAX_OVERFLOW=20
DATABASE_POOL_TIMEOUT=30.0


# ----------------------------------------------------------
# Redis
# Set a strong password; compose builds REDIS_URL from it.
# ----------------------------------------------------------
REDIS_PASSWORD=generate-a-strong-redis-password
# Set only when running outside compose:
# REDIS_URL=redis://:generate-a-strong-redis-password@redis:6379/0


# ----------------------------------------------------------
# Backend / API
# BACKEND_PORT: local-dev host port - change to avoid clashes,
# then set the same port in VITE_API_URL below.
# ----------------------------------------------------------
BACKEND_PORT=8000
API_V1_PREFIX=/api/v1
PROJECT_NAME="GameAI Competition Platform"
LOG_LEVEL=info


# ----------------------------------------------------------
# Rate limiting (format: "10/minute;60/hour")
# ----------------------------------------------------------
RATE_LIMITING_ENABLED=true
# Drop anon IP limits (shared-IP / hackathon).
DISABLE_IP_RATE_LIMITING=false
# Enable only behind a trusted reverse proxy.
TRUST_PROXY_HEADERS=false
RATE_LIMIT_LOGIN=10/minute;60/hour
RATE_LIMIT_REGISTER=6/minute;40/hour
RATE_LIMIT_EMAIL_TOKEN=6/minute;20/hour
RATE_LIMIT_READS=600/minute;10000/hour
RATE_LIMIT_PROFILE=120/minute
RATE_LIMIT_MUTATIONS=120/minute;2000/hour
RATE_LIMIT_UPLOAD=10/minute;60/hour
RATE_LIMIT_MATCH_CREATE=20/minute;200/hour
RATE_LIMIT_STREAM=60/minute
RATE_LIMIT_ADMIN=20000/minute


# ----------------------------------------------------------
# Security / JWT - generate with: openssl rand -hex 32 (min 32 chars)
# ----------------------------------------------------------
JWT_SECRET_KEY=change-me-generate-with-openssl-rand-hex-32
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_HOURS=24


# ----------------------------------------------------------
# CORS / hostnames (comma-separated, https in prod; no JSON/quotes)
# local: http://localhost:3000
# prod:  https://game-ai.ai-club-aachen.com
# ----------------------------------------------------------
ALLOW_ORIGINS=https://game-ai.ai-club-aachen.com
FRONTEND_URL=https://game-ai.ai-club-aachen.com
# Public API hostname(s); no paths.   local: localhost
TRUSTED_HOSTS=api.game-ai.ai-club-aachen.com


# ----------------------------------------------------------
# Frontend
# VITE_API_URL - public backend API the browser calls:
#   local: http://localhost:8000/api/v1   (match BACKEND_PORT)
#   prod:  https://api.game-ai.ai-club-aachen.com/api/v1
# FRONTEND_PORT: local-dev host port.
# ----------------------------------------------------------
FRONTEND_PORT=3000
VITE_API_URL=https://api.game-ai.ai-club-aachen.com/api/v1
MAX_TURN_TIME_LIMIT_SECONDS=120


# ----------------------------------------------------------
# Email / SMTP (required for staging/production)
# Port 465 = implicit TLS (SMTP_USE_TLS=true); 587 = STARTTLS (false).
# ----------------------------------------------------------
SMTP_HOST=mx2f17.netcup.net
SMTP_PORT=465
SMTP_USERNAME=noreply@ai-club-aachen.com
SMTP_PASSWORD=your-smtp-password
SMTP_FROM_ADDRESS=noreply@ai-club-aachen.com
SMTP_FROM_NAME='AI Club Aachen GameAI Platform'
SMTP_USE_TLS=true
# Token expiry - verification 1-168h, reset 5-1440min.
EMAIL_VERIFICATION_TOKEN_EXPIRE_HOURS=24
PASSWORD_RESET_TOKEN_EXPIRE_MINUTES=60
# prod: False   local: True to skip email verification.
BYPASS_EMAIL_VERIFICATION=False


# ----------------------------------------------------------
# Workers
# WORKER_API_KEY: shared secret (openssl rand -hex 32).
# WORKER_BACKEND_URL: leave unset - derived from BACKEND_PORT;
#   set only for workers running outside compose.
# ----------------------------------------------------------
WORKER_API_KEY=change-me-generate-with-openssl-rand-hex-32
# WORKER_BACKEND_URL=http://backend:8000/api/v1
WORKER_LOG_LEVEL=INFO
# Build the base image locally (production: False); registry creds only needed then.
BUILD_LOCAL_BASE_IMAGE=False
DOCKER_REGISTRY_USER=
DOCKER_REGISTRY_PASSWORD=
# Use local gamelib instead of PyPI.
USE_LOCAL_GAMELIB=False
# Used only when workers run outside compose.
BACKEND_URL=http://backend:8000/api/v1


# ----------------------------------------------------------
# Match / job limits (optional; 0 disables a given cap)
# ----------------------------------------------------------
MATCH_STALE_TIMEOUT_SECONDS=60
# Concurrent-strategy target for in-flight matches; set ~= number of match-runner workers
MATCH_MAX_CONCURRENT_MATCHES=4
MAX_AGENTS_PER_ARENA=3
MAX_UPLOAD_BYTES=10485760
MAX_SUBMISSIONS_PER_USER=0
MAX_LOG_APPEND_BYTES=65536
MAX_TOTAL_LOG_BYTES=1048576
MAX_RESULT_BYTES=262144
MAX_GAME_STATE_BYTES=1048576


# ----------------------------------------------------------
# Filesystem paths (change only with matching volumes)
# ----------------------------------------------------------
UPLOAD_DIR=uploads
SUBMISSIONS_DIR=uploads/submissions


# ----------------------------------------------------------
# Test only (backend/tests/conftest.py)
# ----------------------------------------------------------
TEST_DATABASE_URL=postgresql://postgres:change-me-to-a-strong-postgres-password@db:5432/gameai_test
